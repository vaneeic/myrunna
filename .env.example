# ============================================================
# MyRunna — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- Database ---
# Injected automatically by Railway PostgreSQL plugin
DATABASE_URL=postgresql://user:password@localhost:5432/myrunna

# --- JWT Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_EXPIRES_IN=7d

# --- Strava OAuth ---
# Create an app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
# Must match the "Authorization Callback Domain" in Strava app settings
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback

# --- Token Encryption ---
# AES-256 key for encrypting Strava tokens at rest in PostgreSQL
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
STRAVA_TOKEN_ENCRYPTION_KEY=your-64-char-hex-string-here-generate-with-command-above

# --- App URLs ---
FRONTEND_URL=http://localhost:4200
PORT=3000
NODE_ENV=development
