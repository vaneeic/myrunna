{
  "name": "myrunna",
  "version": "1.0.0",
  "private": true,
  "description": "MyRunna — Personal running plan management app",
  "workspaces": [
    "frontend",
    "shared"
  ],
  "scripts": {
    "dev:backend": "dotnet run --project backend/MyRunna.Api.csproj",
    "dev:frontend": "npm run start --workspace=frontend",
    "build:backend": "dotnet publish backend/MyRunna.Api.csproj -c Release",
    "build:frontend": "npm run build --workspace=frontend"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
